<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>

    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} [%-5level] %-45logger{45} - %msg%n</pattern>
        </encoder>
    </appender>

    <logger name="com.multiagent"           level="INFO"  additivity="false">
        <appender-ref ref="CONSOLE"/>
    </logger>
    <logger name="dev.langchain4j"          level="WARN"/>
    <logger name="org.bsc.langgraph4j"      level="WARN"/>
    <logger name="io.github.resilience4j"   level="WARN"/>
    <logger name="org.springframework"      level="WARN"/>
    <logger name="com.zaxxer"              level="WARN"/>

    <root level="WARN">
        <appender-ref ref="CONSOLE"/>
    </root>
</configuration>
